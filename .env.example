# SRTM1 GeoTIFF tile directory for elevation data.
# Set this to the path containing N##/N##E###.tif tiles.
# Defaults to data/srtm1 relative to the project root if not set.
# When empty or the path doesn't exist, falls back to zero-fill.
SRTM1_TILES_DIR=

# Copernicus GLO-30 GeoTIFF tile directory for elevation data.
# Defaults to data/glo30 relative to the project root if not set.
GLO30_TILES_DIR=

# ESA WorldCover land cover tile directory.
# Defaults to data/landcover relative to the project root if not set.
LANDCOVER_DIR=

# CORS origins for production deployment (comma-separated).
# If set, takes precedence over DEV_ORIGINS.
# Example: CORS_ORIGINS=https://nowires.example.com,https://app.example.com
CORS_ORIGINS=

# Elevation cache directory.
# Defaults to data/elev_cache relative to the project root if not set.
# Cache uses deterministic filenames and atomic writes.
ELEV_CACHE_DIR=

# Frontend environment variables (DEV_ORIGINS, BACKEND_URL) are set in
# apps/web/.env.local — see apps/web/.env.local.example for details.
