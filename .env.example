# SRTM1 GeoTIFF tile directory for elevation data.
# Set this to the path containing N##/N##E###.tif tiles.
# Defaults to ~/.cache/elevation/SRTM1/cache if not set.
# When empty or the path doesn't exist, falls back to the OpenTopoData API.
SRTM1_TILES_DIR=

# Copernicus GLO-30 GeoTIFF tile directory for elevation data.
# Defaults to data/glo30 relative to the project root if not set.
GLO30_TILES_DIR=

# ESA WorldCover land cover tile directory.
# Defaults to data/landcover relative to the project root if not set.
LANDCOVER_DIR=

# Frontend environment variables (DEV_ORIGINS, BACKEND_URL) are set in
# apps/web/.env.local — see apps/web/.env.local.example for details.